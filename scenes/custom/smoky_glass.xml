<?xml version="1.0" encoding="utf-8"?>
<!--
  Smoky Glass Chamber: Heterogeneous smoke volume inside a Cornell box,
  viewed through a glass teapot. Combines volumetric rendering with
  surface-volume interactions: the teapot refracts light through the
  smoke, creating complex caustic-like illumination patterns.
  Uses the existing smoke.vol data for the heterogeneous volume.
-->
<scene version="0.5.0">
	<integrator type="volpath">
		<integer name="maxDepth" value="-1"/>
		<integer name="version" value="6"/>
	</integrator>

	<!-- Heterogeneous smoke filling the entire box -->
	<medium type="heterogeneous" id="smoke">
		<string name="method" value="woodcock"/>
		<volume name="density" type="gridvolume">
			<string name="filename" value="../volpath_test/smoke.vol"/>
		</volume>
		<volume name="albedo" type="constvolume">
			<rgb name="value" value="0.95 0.85 0.7"/>
		</volume>
		<float name="scale" value="80"/>
		<phase type="hg">
			<float name="g" value="0.35"/>
		</phase>
	</medium>

	<!-- Thin ambient medium for the rest of the box -->
	<medium type="homogeneous" id="box_haze">
		<rgb name="sigmaA" value="0.005 0.008 0.015"/>
		<rgb name="sigmaS" value="0.03 0.025 0.02"/>
		<float name="scale" value="1.0"/>
	</medium>

	<!-- Dense amber medium inside the teapot -->
	<medium type="homogeneous" id="teapot_juice">
		<rgb name="sigmaA" value="0.02 0.3 1.2"/>
		<rgb name="sigmaS" value="1.5 0.8 0.2"/>
		<float name="scale" value="0.3"/>
		<phase type="hg">
			<float name="g" value="0.5"/>
		</phase>
	</medium>

	<sensor type="perspective">
		<string name="fovAxis" value="x"/>
		<float name="fov" value="45.8402"/>
		<transform name="toWorld">
			<scale x="-1"/>
			<lookat target="-0.166029, 0.148984, -0.537402" origin="-0.61423, 0.154197, -1.43132" up="-0.000640925, -0.999985, -0.0055102"/>
		</transform>

		<sampler type="independent">
			<integer name="sampleCount" value="512"/>
		</sampler>

		<film type="hdrfilm">
			<integer name="height" value="576"/>
			<integer name="width" value="768"/>
			<rfilter type="gaussian"/>
		</film>
	</sensor>

	<!-- Smoke volume bounds -->
	<shape type="obj">
		<string name="filename" value="../volpath_test/bounds.obj"/>
		<ref name="interior" id="smoke"/>
	</shape>

	<!-- Ground plane -->
	<shape type="obj">
		<string name="filename" value="../volpath_test/plane.obj"/>
		<bsdf type="roughplastic">
			<rgb name="diffuseReflectance" value="0.3 0.25 0.2"/>
			<float name="alpha" value="0.05"/>
		</bsdf>
		<transform name="toWorld">
			<translate y=".48"/>
		</transform>
	</shape>

	<!-- Main light from below-left (warm) -->
	<shape type="sphere">
		<point name="center" x="0" y="-2" z="-1"/>
		<float name="radius" value="1"/>
		<emitter type="area">
			<rgb name="radiance" value="18 14 8"/>
		</emitter>
	</shape>

	<!-- Accent light from upper-right (cool) -->
	<shape type="sphere">
		<point name="center" x="0.8" y="1.5" z="-1.5"/>
		<float name="radius" value="0.2"/>
		<emitter type="area">
			<rgb name="radiance" value="8 12 25"/>
		</emitter>
	</shape>

	<!-- A small glass sphere floating in the smoke -->
	<shape type="sphere">
		<point name="center" x="-0.15" y="0.05" z="-0.4"/>
		<float name="radius" value="0.08"/>
		<bsdf type="roughdielectric">
			<float name="intIOR" value="1.5"/>
			<float name="alpha" value="0.01"/>
			<rgb name="specularReflectance" value="1"/>
			<rgb name="specularTransmittance" value="1"/>
		</bsdf>
		<ref name="interior" id="teapot_juice"/>
	</shape>

	<!-- A diffuse warm sphere sitting on the ground -->
	<shape type="sphere">
		<point name="center" x="0.2" y="0.43" z="-0.35"/>
		<float name="radius" value="0.06"/>
		<bsdf type="disneymetal">
			<rgb name="baseColor" value="0.95 0.7 0.3"/>
			<float name="roughness" value="0.15"/>
			<float name="anisotropic" value="0.0"/>
		</bsdf>
	</shape>
</scene>
